# Configurações do Backend - Sirius App
# Copie este arquivo para .env e preencha os valores

# MongoDB Atlas (obrigatório)
MONGO_URL=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<banco>?retryWrites=true&w=majority
DB_NAME=sirius_production

# Google Gemini API (opcional - pode usar chave do usuário)
GOOGLE_GEMINI_API_KEY=

# Telegram Bot (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_WEBHOOK_SECRET=

# JWT Secret (gere uma chave aleatória)
JWT_SECRET=sua_chave_secreta_aqui_mude_em_producao

# Frontend URL (para CORS)
FRONTEND_URL=https://seufrontend.onrender.com

# Environment
ENVIRONMENT=production
